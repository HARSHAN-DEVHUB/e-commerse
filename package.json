{
  "name": "clothing-brand-website",
  "version": "1.0.0",
  "description": "A modern clothing brand e-commerce website built with React.js and JavaScript",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "vite",
    "lint": "eslint . --ext .js,.jsx",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
